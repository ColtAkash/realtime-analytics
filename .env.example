# ============================================================
# Realtime Analytics Dashboard — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# --- Docker Compose Ports ---
# These control which host ports are mapped to each service.
# Change if you have conflicts on your machine.
ZOOKEEPER_PORT=2181          # Zookeeper client port
KAFKA_PORT=9092              # Kafka broker (PLAINTEXT_HOST listener)
CASSANDRA_PORT=9042          # Cassandra CQL native transport
ELASTICSEARCH_PORT=9200      # Elasticsearch HTTP
REDIS_PORT=6379              # Redis
SPARK_MASTER_PORT=7077       # Spark master RPC
SPARK_MASTER_WEB_PORT=8080   # Spark master web UI
API_PORT=8000                # FastAPI server

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=analytics.events

# --- Kafka (Confluent Cloud) ---
CONFLUENT_CLOUD_BOOTSTRAP=
CONFLUENT_CLOUD_API_KEY=
CONFLUENT_CLOUD_API_SECRET=
CONFLUENT_SCHEMA_REGISTRY_URL=
CONFLUENT_SCHEMA_REGISTRY_API_KEY=
CONFLUENT_SCHEMA_REGISTRY_API_SECRET=

# --- Spark ---
SPARK_MASTER=local[*]
SPARK_BATCH_INTERVAL_SECONDS=10

# --- Cassandra ---
CASSANDRA_HOST=localhost
CASSANDRA_KEYSPACE=analytics
CASSANDRA_USERNAME=cassandra
CASSANDRA_PASSWORD=cassandra

# --- Cassandra (Astra DB) ---
# Download your secure connect bundle from Astra DB dashboard, then base64-encode it:
#   base64 -w0 secure-connect-bundle.zip
# Paste the result as ASTRA_SECURE_BUNDLE_B64.
# Client ID and Secret come from Astra DB → Settings → Token (role: R/W User).
ASTRA_SECURE_BUNDLE_B64=
ASTRA_CLIENT_ID=
ASTRA_CLIENT_SECRET=

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=events

# --- Elasticsearch (Bonsai.io) ---
# Bonsai gives you a URL like: https://user:password@host.bonsai.io
# Set ELASTICSEARCH_URL to that full URL — no other changes needed.

# --- Elasticsearch (Elastic Cloud) ---
ELASTIC_CLOUD_ID=
ELASTIC_CLOUD_API_KEY=

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=60

# --- FastAPI ---
API_HOST=0.0.0.0
API_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:5173

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws

# --- AWS (Terraform) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- Data Producer ---
PRODUCER_EVENTS_PER_SECOND=10
PRODUCER_EVENT_TYPES=pageview,click,purchase